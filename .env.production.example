# ─────────────────────────────────────────────────────────────
# 生产部署环境变量样例（轻量化版本）
# 复制为 .env.production 后填写真实值，并加入 .gitignore，禁止提交。
# ─────────────────────────────────────────────────────────────

# ── DuckDB（嵌入式数据库）─────────────────────────────────
# 不需要密码 / host / port，连接即文件路径。生产 compose 把 backend_data 卷挂到 /data，
# DUCKDB_PATH 在 docker-compose.yml 里固定写成 /data/dashboard.duckdb，无需在这里覆盖。

# ── 鉴权 ───────────────────────────────────────────────────
# 生成命令：openssl rand -hex 32   （至少 32 字节）
JWT_SECRET=please_generate_with_openssl_rand_hex_32
JWT_EXPIRE_HOURS=8

# Cookie 安全位（关键！必须与传输协议匹配）
#   HTTPS 上线 → COOKIE_SECURE=true（浏览器才接受）
#   HTTP 临时模式 → COOKIE_SECURE=false（否则浏览器拒种 cookie，登录后反复跳登录页）
# 这一行不能漏，否则走默认值 true，HTTP 模式下登录会失败
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── 用户 backend：file（默认）或 sqlite ─────────────────────
# file 模式：所有用户写在 AUTH_USERS，格式 "user1:bcrypt_hash;user2:bcrypt_hash"
#   生成 bcrypt：python -m auth.cli hash 你的密码
# sqlite 模式：注释掉 AUTH_USERS，改用 CLI 管理
#   docker compose --env-file .env.production exec backend python -m auth.cli add-user alice -p secret
AUTH_BACKEND=sqlite
# AUTH_USERS=admin:$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

# ── 用户自助注册（可选）─────────────────────────────────────
# 仅 AUTH_BACKEND=sqlite 时生效；空串=注册功能完全关闭。
# 邀请码会在前端表单显式要求，与服务端字符串完全一致才放行。
# 强烈建议：上线后不要把邀请码写进任何文档或代码仓库。
REGISTRATION_CODE=

# ── 定时任务 ───────────────────────────────────────────────
# 境内服务器跨境出口受限时建议保持 false（爬虫跑了也是失败循环，徒耗 CPU/内存）
# 海外节点或本地跑可置 true
SCHEDULE_ENABLED=false
SCHEDULE_HOUR=2
SCHEDULE_MINUTE=0
SCHEDULE_LIMIT=100

# ── 是否在 backend 镜像里装 Chromium（约 +300MB）──────────
# 生产 1C2G 节点保持 false；海外节点 / 本地 dev 跑爬虫时改 true 并重 build：
#   docker compose --env-file .env.production build --build-arg INSTALL_PLAYWRIGHT_CHROMIUM=true backend
INSTALL_PLAYWRIGHT_CHROMIUM=false
