# ─────────────────────────────────────────────────────────────
# 生产部署环境变量样例
# 复制为 .env.production 后填写真实值，并加入 .gitignore，禁止提交。
# ─────────────────────────────────────────────────────────────

# 域名（必填）—— Caddy 自动签证书，需提前把 A 记录指向 ECS 公网 IP
DOMAIN=your-domain.com
ADMIN_EMAIL=ops@your-domain.com

# ── ClickHouse ─────────────────────────────────────────────
# 默认走 compose 内置的 clickhouse 容器（同栈部署，无外部依赖）：
#   CLICKHOUSE_HOST=clickhouse （即容器名，docker DNS 自动解析）
# 如要接外部 ClickHouse（VPC 内网 / 公司机房），把 host 改成实际地址，
# 然后启动时排除内置 clickhouse：
#   docker compose --env-file .env.production up -d --build --scale clickhouse=0
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=analysis
CLICKHOUSE_USERNAME=app
CLICKHOUSE_PASSWORD=change_me_to_a_strong_random_string

# ── 鉴权 ───────────────────────────────────────────────────
# 生成命令：openssl rand -hex 32   （至少 32 字节）
JWT_SECRET=please_generate_with_openssl_rand_hex_32
JWT_EXPIRE_HOURS=8

# Cookie：HTTPS 下必须 true；同站策略一般 lax 即可
COOKIE_SAMESITE=lax

# ── 用户 backend：file（默认）或 sqlite ─────────────────────
# file 模式：所有用户写在 AUTH_USERS，格式 "user1:bcrypt_hash;user2:bcrypt_hash"
#   生成 bcrypt：python -m auth.cli hash 你的密码
# sqlite 模式：注释掉 AUTH_USERS，改用 CLI 管理
#   python -m auth.cli add-user alice -p secret
AUTH_BACKEND=file
AUTH_USERS=admin:$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH

# AUTH_BACKEND=sqlite
# AUTH_USERS=
# AUTH_SQLITE_PATH 在 compose 内固定为 /data/auth_users.db（持久卷）

# ── 用户自助注册（可选）─────────────────────────────────────
# 仅 AUTH_BACKEND=sqlite 时生效；空串=注册功能完全关闭。
# 邀请码会在前端表单显式要求，与服务端字符串完全一致才放行。
# 修改邀请码 = 立即作废历史邀请，已注册用户不受影响。
# 强烈建议：上线后不要把邀请码写进任何文档或代码仓库。
REGISTRATION_CODE=

# ── 定时任务 ───────────────────────────────────────────────
SCHEDULE_ENABLED=true
SCHEDULE_HOUR=2
SCHEDULE_MINUTE=0
SCHEDULE_LIMIT=100
